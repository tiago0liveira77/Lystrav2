rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isUser(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isPremium(uid) {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(uid)).data.isPremium == true;
    }

    function isHouseholdMember(householdId) {
      return isAuthenticated() &&
        request.auth.uid in get(/databases/$(database)/documents/households/$(householdId)).data.memberIds;
    }

    // User documents — only the owner can read/write
    match /users/{uid} {
      allow read, write: if isUser(uid);

      // Personal lists
      match /lists/{listId} {
        allow read, write: if isUser(uid);

        // List entries
        match /entries/{entryId} {
          allow read, write: if isUser(uid);
        }
      }

      // Personal items catalogue
      match /items/{itemId} {
        allow read, write: if isUser(uid);
      }

      // Categories
      match /categories/{categoryId} {
        allow read, write: if isUser(uid);
      }

      // Purchase history
      match /purchase_records/{recordId} {
        allow read, write: if isUser(uid);
      }
    }

    // Households — accessible to all members (premium feature)
    match /households/{householdId} {
      // Any member can read
      allow read: if isAuthenticated() &&
        request.auth.uid in resource.data.memberIds;

      // Only owner can update (add/remove members)
      allow update: if isAuthenticated() &&
        request.auth.uid == resource.data.ownerId;

      // Any authenticated premium user can create a household
      allow create: if isPremium(request.auth.uid);

      // Only owner can delete
      allow delete: if isAuthenticated() &&
        request.auth.uid == resource.data.ownerId;
    }
  }
}
